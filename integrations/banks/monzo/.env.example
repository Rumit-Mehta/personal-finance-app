# Create an OAuth client at https://developers.monzo.com/
# Redirect URL for the local auth server:
# http://localhost:4545/oauth/callback
MONZO_CLIENT_ID=
MONZO_CLIENT_SECRET=
MONZO_REDIRECT_URI=http://localhost:4545/oauth/callback

# Optional local settings.
MONZO_PORT=4545
MONZO_TOKEN_PATH=./data/monzo-token.json
MONZO_OUTPUT_PATH=./data/monzo-data.json
